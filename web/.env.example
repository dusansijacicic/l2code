# Javno (browser + server)
# Supabase: Project Settings → API — URL uvek https://REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Samo server (Vercel env, nikad u klijent / Git)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PayPal REST (developer.paypal.com) — sandbox dok testiraš
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# sandbox | live
PAYPAL_ENV=sandbox

